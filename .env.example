# Backend runtime paths
HELIOS_DATABASE_PATH=data/helios.db
HELIOS_MODEL_PATH=artifacts/moisture_model.pkl
HELIOS_METADATA_PATH=artifacts/model_metadata.json

# CORS origins for the FastAPI backend. Comma-separated when multiple origins are needed.
HELIOS_CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Basic prototype traffic controls
HELIOS_RATE_LIMIT_WINDOW_SECONDS=60
HELIOS_RATE_LIMIT_MAX_REQUESTS=60

# Set to 1 to fail fast when model artifacts are missing at startup.
HELIOS_STRICT_MODEL_STARTUP=0

# Logging
HELIOS_LOG_LEVEL=INFO

# API key for protecting POST endpoints (/predict, /api/feedback).
# When empty or unset, auth is disabled (prototype/demo mode).
# Set to a long random string (e.g. openssl rand -hex 32) before exposing to the internet.
HELIOS_API_KEY=
